{
  "$schema": "../gen/schemas/windows-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*" }, { "url": "http://*" }]
    },
    "dialog:default",
    "dialog:allow-open"
  ]
}
