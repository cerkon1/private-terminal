{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Private Terminal",
  "mainBinaryName": "personal-terminal",
  "version": "1.0.0-rc.1",
  "identifier": "com.personal.terminal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Private Terminal",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src ipc: http://ipc.localhost https://api.stlouisfed.org"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
